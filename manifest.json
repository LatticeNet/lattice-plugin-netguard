{
  "schema": "lattice.plugin.manifest.v2",
  "id": "latticenet.netguard",
  "name": "NetGuard (nftables security groups)",
  "type": "system",
  "capabilities": [
    "node:read",
    "network:plan",
    "network:apply",
    "task:run"
  ],
  "version": "0.1.0-alpha.6",
  "publisher": "latticenet",
  "signature_ed25519": "ae/PSm8uBpTglG7uWWb4xhXcJb607mubD7yDArnp78fLQUna3dlPvK7VYX9Z3dr9uBDGlpTXEAeglR6WBopdAw==",
  "bundle": {
    "format": "tar+gzip",
    "digest_sha256": "a4c6e8428cf3ff18db125cbb8a8454076523136b885f21b2a5eeaf9dce723f50"
  },
  "runtime": {
    "protocol": "stdio-json-v1",
    "entrypoints": {
      "linux/amd64": "bin/linux-amd64/plugin",
      "linux/arm64": "bin/linux-arm64/plugin"
    }
  },
  "ui_runtime": {
    "mode": "sandbox",
    "entrypoint": "ui/index.html",
    "bridge_version": "1"
  },
  "compatibility": {
    "server": "\u003e=0.2.1",
    "dashboard_host": "\u003e=1",
    "runtime_protocol": "\u003e=1"
  },
  "ui": {
    "nav": [
      {
        "section": "extensions",
        "section_title": "Extensions",
        "title": "NetGuard",
        "route": "firewall",
        "icon": "Shield",
        "scopes": [
          "netguard:read"
        ]
      }
    ],
    "views": [
      {
        "route": "firewall",
        "title": "NetGuard Firewall",
        "kind": "sandbox"
      }
    ]
  },
  "interfaces": [
    {
      "service": "latticenet.netguard/firewall",
      "methods": [
        {
          "name": "overview",
          "effect": "read",
          "scopes": [
            "netguard:read"
          ]
        },
        {
          "name": "upsert_group",
          "effect": "write",
          "scopes": [
            "netguard:admin"
          ]
        },
        {
          "name": "delete_group",
          "effect": "write",
          "scopes": [
            "netguard:admin"
          ]
        },
        {
          "name": "upsert_zone",
          "effect": "write",
          "scopes": [
            "netguard:admin"
          ]
        },
        {
          "name": "delete_zone",
          "effect": "write",
          "scopes": [
            "netguard:admin"
          ]
        },
        {
          "name": "upsert_binding",
          "effect": "write",
          "scopes": [
            "netguard:admin"
          ]
        },
        {
          "name": "adopt",
          "effect": "write",
          "scopes": [
            "netguard:admin"
          ]
        },
        {
          "name": "plan",
          "effect": "plan",
          "scopes": [
            "netguard:admin",
            "network:plan"
          ]
        }
      ]
    }
  ]
}
